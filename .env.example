# Postgres connection string used by Prisma at runtime (pooled connection,
# e.g. Supabase's "Transaction" pooler URL on port 6543).
DATABASE_URL="postgresql://user:password@host:6543/postgres?pgbouncer=true"

# Direct (non-pooled) connection string, used only for `prisma migrate` /
# `prisma db push`. On Supabase this is the port 5432 connection string.
DIRECT_URL="postgresql://user:password@host:5432/postgres"
